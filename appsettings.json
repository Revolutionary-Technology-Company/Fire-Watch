using System;
using System.IO;
using System.Collections.Generic;
using System.Linq;
using Microsoft.Extensions.Configuration;

namespace GenetecEdwardsBridge
{
    public class JsonConfigLoader
    {
        // Global variables to hold parsed configurations
        public GenetecSettings GenetecConfig { get; private set; }
        public EdwardsSettings EdwardsConfig { get; private set; }
        
        // Highly optimized lookup dictionary (Key: Camera GUID string in lowercase)
        public Dictionary<string, CameraMapping> LookupMap { get; private set; }

        public void LoadConfiguration()
        {
            try
            {
                // 1. Build the configuration reader targeting appsettings.json
                var builder = new ConfigurationBuilder()
                    .SetBasePath(AppDomain.CurrentDomain.BaseDirectory)
                    .AddJsonFile("appsettings.json", optional: false, reloadOnChange: true);

                IConfigurationRoot configuration = builder.Build();

                // 2. Extract specific configuration sections straight into POCO classes
                GenetecConfig = configuration.GetSection("GenetecConfig").Get<GenetecSettings>();
                EdwardsConfig = configuration.GetSection("EdwardsConfig").Get<EdwardsSettings>();

                // 3. Extract the array of mappings
                var mappings = configuration.GetSection("HospitalMap").Get<List<CameraMapping>>() ?? new List<CameraMapping>();

                // 4. Transform the list into an in-memory dictionary for immediate O(1) lookups
                LookupMap = mappings
                    .Where(m => !string.IsNullOrEmpty(m.CameraGuid))
                    .ToDictionary(
                        m => m.CameraGuid.ToLower().Trim(), 
                        m => m
                    );
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException($"Critical failure parsing appsettings.json: {ex.Message}", ex);
            }
        }
    }
}
